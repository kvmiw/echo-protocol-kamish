<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:profile="clr-namespace:Content.Client.Lobby.UI.ProfileEditorControls">
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalExpand="True">
        <ContainerButton Name="SelectButton"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        StyleClasses="button">
            <BoxContainer Orientation="Horizontal"
                        HorizontalExpand="True"
                        SeparationOverride="0"
                        Name="InternalHBox">
                <profile:ProfilePreviewSpriteView Scale="2 2"
                                                Margin="0 4 4 4"
                                                OverrideDirection="South"
                                                Name="View"
                                                SetSize="64 64"/>
                <Label Name="DescriptionLabel"
                    ClipText="True"
                    HorizontalExpand="True"/>
            </BoxContainer>
        </ContainerButton>
        <Button Name="DeleteButton">
            <TextureRect TexturePath="/Textures/Interface/VerbIcons/delete_transparent.svg.192dpi.png"
                        TextureScale="0.75 0.75"
                        Stretch="KeepAspectCentered"
                        VerticalAlignment="Center"
                        Margin="4"/>
        </Button>
        <Button Name="ConfirmDeleteButton"
                Visible="False"
                StyleClasses="negative">
            <TextureRect TexturePath="/Textures/Interface/VerbIcons/delete_transparent.svg.192dpi.png"
                        TextureScale="0.75 0.75"
                        Stretch="KeepAspectCentered"
                        VerticalAlignment="Center"
                        Margin="4"/>
        </Button>
    </BoxContainer>
</Control>
